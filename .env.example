# BeforeMed — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must never be committed.

# --- Supabase (auth + database) -------------------------------------------
# Found in your Supabase project: Settings → API
# If these are left as placeholders, the app runs without auth (dev mode).
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Anthropic Claude (patient chat + scoring) ----------------------------
# Get a key at https://console.anthropic.com → API Keys (starts with "sk-ant-")
# If left as the placeholder, the simulation uses built-in mock responses
# instead of calling Claude — the app still works end to end.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: override the Claude model used for chat and scoring.
# Defaults to claude-sonnet-4-20250514 when unset.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
